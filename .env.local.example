# Discord OAuth App — https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Discord Bot token (used only by /bot, not Next.js)
DISCORD_BOT_TOKEN=your_discord_bot_token

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret  # openssl rand -base64 32
NEXTAUTH_URL=https://your-project.vercel.app

# Supabase — https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# The Discord guild (server) ID to scope projects to
NEXT_PUBLIC_GUILD_ID=your_discord_guild_id
